# ======================================================
# Auto detect text files
# ======================================================
* text=auto

# ======================================================
# Java Source Files
# ======================================================
*.java text diff=java

# ======================================================
# Spring Configuration
# ======================================================
*.properties text
*.yml text
*.yaml text
*.xml text

# ======================================================
# Markdown & Docs
# ======================================================
*.md text

# ======================================================
# Shell Scripts
# ======================================================
*.sh text eol=lf

# ======================================================
# Windows Scripts
# ======================================================
*.bat text eol=crlf

# ======================================================
# Binary Files
# ======================================================
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.jar binary
*.keystore binary

# ======================================================
# Docker
# ======================================================
Dockerfile text eol=lf